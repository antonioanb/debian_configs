{
    "workbench.iconTheme": "simple-icons",
    "editor.fontFamily": "Hack Nerd Font Mono",
    "editor.fontSize": 15,
    "editor.cursorBlinking": "expand",
    "editor.wordWrap": "on",
    "window.menuBarVisibility": "compact",

    "workbench.colorCustomizations": {
        // --- FUNDO GERAL (DARK TOTAL) ---
        "editor.background": "#05070a",       // Fundo do código
        "sideBar.background": "#05070a",     // Fundo da barra lateral (arquivos)
        "activityBar.background": "#05070a", // Fundo da barra de ícones (extremo esquerdo)
        "terminal.background": "#05070a",    // Fundo do terminal integrado

        // --- BARRA DE TÍTULO (TOPO DO VS CODE) ---
        "titleBar.activeBackground": "#05070a",   // Fundo do topo quando janeta está ativa
        "titleBar.activeForeground": "#6272a4",   // Cor do texto e botões (fechar/minimizar) no topo
        "titleBar.inactiveBackground": "#05070a", // Fundo do topo quando você clica fora do VS Code
        "titleBar.inactiveForeground": "#44475a", // Cor do texto no topo quando inativo

        // --- ABAS (TABS) ---
        "editorGroupHeader.tabsBackground": "#05070a", // Fundo da fileira de abas
        "tab.activeBackground": "#05070a",           // Fundo da aba que você está editando
        "tab.inactiveBackground": "#020305",         // Fundo das abas que estão abertas mas não focadas
        "tab.activeForeground": "#8be9fd",           // Cor do texto da aba ativa (Ciano)
        "tab.inactiveForeground": "#6272a4",         // Cor do texto das abas inativas
        "tab.activeBorderTop": "#6272a4",            // Linha colorida acima da aba aberta
        "tab.border": "#05070a",                     // Divisória entre uma aba e outra

        // --- LISTA DE ARQUIVOS (EXPLORER) ---
        "list.activeSelectionBackground": "#44475a", // Cor do RETÂNGULO de seleção (ajustado para cinza Dracula)
        "list.activeSelectionForeground": "#ffffff", // Cor do TEXTO do arquivo selecionado (Branco para não sumir)
        "list.inactiveSelectionBackground": "#282a36", // Cor da seleção quando você clica em outro lugar
        "list.inactiveSelectionForeground": "#ffffff", // Texto da seleção inativa
        "list.hoverBackground": "#05070a",           // Fundo quando passa o mouse por cima
        "list.hoverForeground": "#8be9fd",           // Texto quando passa o mouse por cima

        // --- OUTROS DETALHES DA INTERFACE ---
        "activityBar.activeBorder": "#6272a4",      // Linha lateral do ícone ativo
        "activityBar.foreground": "#6272a4",        // Cor do ícone lateral ativo
        "notificationBadge.background": "#8be9fd",  // Bolinha de avisos/notificações
        "activityBarBadge.background": "#6272a4",   // Bolinha de notificação na barra lateral
        "progressBar.background": "#6272a4"         // Barra de progresso (ex: quando salva ou carrega algo)
    },

    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "comment",
                "settings": {
                    "foreground": "#343746",
                    "fontStyle": "italic"
                }
            }
        ]
    },
    "workbench.colorTheme": "Dracula Theme"
}
